    "expected_output": "5! = 120",
    "initial_code": [
      "#include <iostream>",
      "using namespace std;",
      "",
      "int factorial(int n) {",
      "    // バグ: 0! = 1 のはずが 0 を返してしまっている",
      "    if (n <= 0) return 0;",
      "    return n * factorial(n - 1);",
      "}",
      "",
      "int main() {",
      "    int n;",
      "    cin >> n;",
      "",
      "    cout << n << \"! = \" << factorial(n) << endl;",
      "",
      "    return 0;",
      "}"
    ]
  },


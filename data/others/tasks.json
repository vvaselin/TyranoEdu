    "stdin": "8",
    "expected_output": "1\n1\n2\n3\n5\n8\n13\n21",
    "initial_code": [
      "#include <iostream>",
      "using namespace std;",
      "",
      "int main() {",
      "    int n;",
      "    cin >> n;",
      "",
      "    // ← 最初の2項は何?",
      "    int a = 0, b = 1;",
      "",
      "    for (int i = 0; i < n; i++) {",
      "        cout << a << endl;",
      "        int next = a + b;",

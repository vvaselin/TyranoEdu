    "expected_output": "fib(10) = 55",
    "initial_code": [
      "#include <iostream>",
      "using namespace std;",
      "",
      "int fib(int n) {",
      "    // ← fib(1) と fib(2) も考えよう",
      "    if (n <= 0) return 0;",
      "    return fib(n - 1) + fib(n - 2);",
      "}",
      "",
      "int main() {",
      "    int n;",
      "    cin >> n;",
      "",
      "    cout << \"fib(\" << n << \") = \" << fib(n) << endl;",
      "",
      "    return 0;",
      "}"
    ]
  },


  "task21": {
    "category": "関数",
    "title": "課題4-3: 階乗（ループ版）",
    "description": "整数 n が入力されたとき、\nn の階乗（n!）を計算する\n関数 factorial を完成させてください。",
    "stdin": "6",
    "expected_output": "6! = 720",
    "initial_code": [
      "#include <iostream>",
      "using namespace std;",
      "",
      "int factorial(int n) {",
      "    // ← 掛け算の初期値は何がよい?",
      "    int result = 0;",
      "    for (int i = 1; i <= n; i++) {",
      "        result *= i;",
      "    }",
      "    return result;",
      "}",
      "",
      "int main() {",
      "    int n;",
      "    cin >> n;",
      "",
      "    cout << n << \"! = \" << factorial(n) << endl;",
      "",
      "    return 0;",
      "}"
    ]
  },

  "task22": {
    "category": "関数",
    "title": "課題4-4: 再帰関数（階乗）",
    "description": "再帰を使って\nn の階乗（n!）を計算する\n関数を完成させてください。",
    "stdin": "5",
    "expected_output": "5! = 120",
    "initial_code": [
      "#include <iostream>",
      "using namespace std;",
      "",
      "int factorial(int n) {",
      "    if (n <= 0) return 0;  // ← 0! はいくつ?",
      "    return n * factorial(n - 1);",
      "}",
      "",
      "int main() {",
      "    int n;",
      "    cin >> n;",
      "",
      "    cout << n << \"! = \" << factorial(n) << endl;",
      "",
      "    return 0;",
      "}"
    ]
  },


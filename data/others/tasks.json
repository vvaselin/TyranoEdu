  "task14": {
    "title": "課題14: 再帰関数（階乗）",
    "description": "再帰関数を使って n の階乗（n!）を計算するプログラムを作成してください。\n\n入力例: 5\n出力例: 5! = 120",
    "stdin": "5",
    "expected_output": "5! = 120",
    "initial_code": [
      "#include <iostream>",
      "using namespace std;",
      "",
      "int factorial(int n) {",
      "    // バグ: 0! = 1 のはずが 0 を返してしまっている",
      "    if (n <= 0) return 0;",
      "    return n * factorial(n - 1);",
      "}",
      "",
      "int main() {",
      "    int n;",
      "    cin >> n;",
      "",
      "    cout << n << \"! = \" << factorial(n) << endl;",
      "",
      "    return 0;",
      "}"
    ]
  },

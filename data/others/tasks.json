      "        cin >> arr[i];",
      "    }",
      "",
      "    for (int i = 0; i < 4; i++) {",
      "        for (int j = 0; j < 4 - i; j++) {",
      "            // バグ: この比較演算子だと降順になってしまう",
      "            if (arr[j] < arr[j + 1]) {",
      "                int tmp = arr[j];",
      "                arr[j] = arr[j + 1];",
      "                arr[j + 1] = tmp;",
      "            }",
      "        }",
      "    }",
      "",
      "    for (int i = 0; i < 5; i++) {",
      "        cout << arr[i] << endl;",
      "    }",
      "",
      "    return 0;",
      "}"
    ]
  },

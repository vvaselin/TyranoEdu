  "task21": {
    "category": "関数",
    "title": "課題21: 階乗を計算する関数（ループ版）",
    "description": "ループを使って n の階乗（n!）を計算する関数 factorial を完成させてください。\n\n入力例: 6\n出力例: 6! = 720",
    "stdin": "6",
    "expected_output": "6! = 720",
    "initial_code": [
      "#include <iostream>",
      "using namespace std;",
      "",
      "int factorial(int n) {",
      "    // バグ: result を 0 で初期化すると掛け算が全て 0 になってしまう",
      "    int result = 0;",
      "    for (int i = 1; i <= n; i++) {",
      "        result *= i;",
      "    }",
      "    return result;",
      "}",
      "",
      "int main() {",
      "    int n;",
      "    cin >> n;",
      "",
      "    cout << n << \"! = \" << factorial(n) << endl;",
      "",

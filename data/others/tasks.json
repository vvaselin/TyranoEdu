      "    // a≦b≦c と a≦c≦b しか考えていない",
      "    // ← 残りの並び順も考えよう",
      "    if (a <= b && b <= c) mid = b;",
      "    else if (a <= c && c <= b) mid = c;",
      "    else mid = a;",
      "",
      "    cout << \"中央値: \" << mid << endl;",
      "",
      "    return 0;",
      "}"
    ]
  },

